{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "https://portfolio-analyzer-agent.vercel.app/dashboard"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "https://portfolio-analyzer-agent.vercel.app/dashboard/:path*"
    },
    {
      "source": "/blog/es/:slug",
      "destination": "/blog/es/:slug.html"
    },
    {
      "source": "/blog/:slug",
      "destination": "/blog/:slug.html"
    },
    {
      "source": "/blog",
      "destination": "/blog/blog-index.html"
    }
  ]
}
